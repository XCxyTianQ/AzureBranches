From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: AzureBranches <azurebranches@local>
Date: Thu, 16 Jul 2026 17:06:27 +0800
Subject: [PATCH] AzureBranches - EXP awaitable /setblock + same-region fast
 path

---
 .../server/commands/SetBlockCommand.java      |  5 ++++
 .../world/level/block/CommandBlock.java       | 23 +++++++++++++++----
 2 files changed, 24 insertions(+), 4 deletions(-)

diff --git a/net/minecraft/server/commands/SetBlockCommand.java b/net/minecraft/server/commands/SetBlockCommand.java
index 582d977..3d96fb1 100644
--- a/net/minecraft/server/commands/SetBlockCommand.java
+++ b/net/minecraft/server/commands/SetBlockCommand.java
@@ -112,6 +112,9 @@ public class SetBlockCommand {
         final boolean strict
     ) throws CommandSyntaxException {
         ServerLevel level = source.getLevel();
+        // AzureBranches start - EXP awaitable result (null unless inside an EXP command block chain)
+        final java.util.concurrent.CompletableFuture<Boolean> abFuture = com.azurebranches.command.ExpChainSupport.registerRemote();
+        // AzureBranches end
         // Folia start - region threading
         io.papermc.paper.threadedregions.RegionizedServer.getInstance().taskQueue.queueOrExecuteTickTask(
                 level, pos.getX() >> 4, pos.getZ() >> 4, () -> {
@@ -140,11 +143,13 @@ public class SetBlockCommand {
                 }
 
                 source.sendSuccess(() -> Component.translatable("commands.setblock.success", pos.getX(), pos.getY(), pos.getZ()), true);
+                if (abFuture != null) abFuture.complete(Boolean.TRUE); // AzureBranches - EXP real result
                 return; // Folia - region threading
             }
         }
         // Folia start - region threading
                 } catch (CommandSyntaxException ex) {
+                    if (abFuture != null) abFuture.complete(Boolean.FALSE); // AzureBranches - EXP real result
                     sendMessage(source, ex);
                 }
             });
diff --git a/net/minecraft/world/level/block/CommandBlock.java b/net/minecraft/world/level/block/CommandBlock.java
index 0539d79..60425ac 100644
--- a/net/minecraft/world/level/block/CommandBlock.java
+++ b/net/minecraft/world/level/block/CommandBlock.java
@@ -290,10 +290,25 @@ public class CommandBlock extends BaseEntityBlock implements GameMasterBlock {
                             break;
                         }
                         if (!futures.isEmpty()) {
-                            st.direction = state.getValue(FACING);
-                            suspendChainExp(st, st.pos.immutable(), futures);
-                            suspended = true;
-                            return;
+                            boolean allDone = true;
+                            for (java.util.concurrent.CompletableFuture<Boolean> f : futures) {
+                                if (!f.isDone()) { allDone = false; break; }
+                            }
+                            if (allDone) {
+                                // Same-region fast path: results are already known. Apply the
+                                // true outcome inline and keep walking - also prevents unbounded
+                                // recursion from a synchronous suspend/resume round-trip.
+                                java.util.List<Boolean> doneResults = new java.util.ArrayList<>(futures.size());
+                                for (java.util.concurrent.CompletableFuture<Boolean> f : futures) {
+                                    doneResults.add(!f.isCompletedExceptionally() ? f.getNow(Boolean.FALSE) : Boolean.FALSE);
+                                }
+                                baseCommandBlock.setSuccessCount(com.azurebranches.command.ExpChainSupport.aggregate(doneResults));
+                            } else {
+                                st.direction = state.getValue(FACING);
+                                suspendChainExp(st, st.pos.immutable(), futures);
+                                suspended = true;
+                                return;
+                            }
                         }
                         level.updateNeighbourForOutputSignal(st.pos, block);
                     } else if (commandBlock.isConditional()) {
