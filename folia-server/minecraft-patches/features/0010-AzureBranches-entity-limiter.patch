+            if (com.azurebranches.entity.EntityLimiter.get() != null) {
+                com.azurebranches.entity.EntityLimiter.get().onRegionTickStart(this);
+            }
+            // AzureBranches end - entity limits
             regionizedWorldData // Folia - regionised ticking
                 .forEachTickingEntity( // Folia - regionised ticking
                     entity -> {
@@ -952,6 +957,11 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
                     }
                 );
             } finally { foliaProfiler.stopTimer(ca.spottedleaf.leafprofiler.LProfilerRegistry.ENTITY_TICK); } // Folia - profiler
+            // AzureBranches start - entity limits
+            if (com.azurebranches.entity.EntityLimiter.get() != null) {
+                com.azurebranches.entity.EntityLimiter.get().onRegionTickEnd(this);
+            }
+            // AzureBranches end - entity limits
             if (this.paperConfig().unsupportedSettings.ticking.blockEntities) { // Paper - option to disable ticking
             profiler.popPush("blockEntities");
             foliaProfiler.startTimer(ca.spottedleaf.leafprofiler.LProfilerRegistry.TILE_ENTITY); try { // Folia - profiler
@@ -1485,6 +1495,19 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
     // Paper end - log detailed entity tick information
 
     public void tickNonPassenger(final Entity entity) {
+        // AzureBranches start - entity limits
+        final com.azurebranches.entity.EntityLimiter limiter = com.azurebranches.entity.EntityLimiter.get();
+        if (limiter != null && limiter.isEnabled()) {
+            final com.azurebranches.entity.EntityLimiter.Decision d = limiter.check(entity.getBukkitEntity(), this);
+            if (d == com.azurebranches.entity.EntityLimiter.Decision.REMOVE) {
+                entity.discard();
+                return;
+            }
+            if (d == com.azurebranches.entity.EntityLimiter.Decision.SKIP) {
+                return;
+            }
+        }
+        // AzureBranches end - entity limits
         // Paper start - log detailed entity tick information
         ca.spottedleaf.moonrise.common.util.TickThread.ensureTickThread("Cannot tick an entity off-main");
         try {
